{
  "name": "jmeter-mcp",
  "version": "1.0.0",
  "description": "MCP server plugin for Apache JMeter - run test plans, analyze results, compare performance",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jmeter-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
